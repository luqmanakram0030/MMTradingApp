<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    Title="AddEmployee"
    x:Class="MMAdmin.Views.ShopManagement.AddShop"
    x:DataType="vm:AddShopViewModel"
    x:Name="AddShopPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:behaviors="clr-namespace:MMAdmin.Behaviors"
    xmlns:models="clr-namespace:MMAdmin.Domain.Models"
    xmlns:res="clr-namespace:MMAdmin.Resources.Languages"
    xmlns:vm="clr-namespace:MMAdmin.ViewModels.ShopManagement"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid
        Margin="20,10"
        RowDefinitions="*,Auto"
        RowSpacing="15">
        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="15">
                <!--  Header  -->
                <StackLayout Grid.Row="0" Orientation="Horizontal">
                    <!--  Back button  -->
                    <Frame
                        BorderColor="Gray"
                        HorizontalOptions="Start"
                        Padding="0"
                        VerticalOptions="Start">
                        <ImageButton
                            Command="{Binding GoBackCommand}"
                            CommandParameter="{Binding Source={x:Reference AddShopPage}}"
                            HeightRequest="30"
                            HorizontalOptions="Start"
                            Padding="0"
                            VerticalOptions="Start"
                            x:Name="btngoback">
                            <ImageButton.Source>
                                <FontImageSource
                                    Color="{StaticResource PrimaryBlack}"
                                    FontFamily="FontIcons"
                                    Glyph="&#xf0141;"
                                    Size="40" />
                            </ImageButton.Source>
                        </ImageButton>
                    </Frame>
                    <Label
                        FontFamily="Bold"
                        FontSize="20"
                        HorizontalOptions="CenterAndExpand"
                        Text="Add Shop"
                        TextColor="{StaticResource PrimaryBlack}"
                        VerticalOptions="CenterAndExpand"
                        x:Name="lblTitle" />
                </StackLayout>

                <!--  Shop Name  -->
                <Border
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="selectedshop.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            Grid.Column="1"
                            Placeholder="Shop Name"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedShop.Name}"
                            x:Name="txtShopName" />
                    </Grid>
                </Border>
                <Label
                    Grid.Row="2"
                    IsVisible="False"
                    TextColor="Red"
                    x:Name="ShopModel_NameError" />

                <!--  Owner Name  -->
                <Border Grid.Row="3" Style="{StaticResource PrimaryBorder}">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="icon_profile.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            Grid.Column="1"
                            Placeholder="Owner Name"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedShop.OwnerName}" />
                    </Grid>
                </Border>
                <Label
                    Grid.Row="4"
                    IsVisible="False"
                    TextColor="Red"
                    x:Name="ShopModel_OwnerNameError" />

                <!--  Phone Number  -->
                <Border Grid.Row="5" Style="{StaticResource PrimaryBorder}">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="icon_call.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            Grid.Column="1"
                            Placeholder="Phone No."
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedShop.PhoneNumber}">
                            <Entry.Behaviors>
                                <behaviors:PhoneNumberMaskBehavior x:Name="PhoneMask" />

                            </Entry.Behaviors>
                        </Entry>
                    </Grid>
                </Border>
                <Label
                    Grid.Row="6"
                    IsVisible="False"
                    TextColor="Red"
                    x:Name="ShopModel_PhoneNumberError" />

                <!--  Selected Location  -->
                <Border Grid.Row="7" Style="{StaticResource PrimaryBorder}">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="selectedshop.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            Grid.Column="1"
                            IsEnabled="False"
                            Placeholder="Selected location appears here"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedPlaceDetails.Address}" />
                    </Grid>
                </Border>
                <Label
                    Grid.Row="8"
                    IsVisible="False"
                    TextColor="Red"
                    x:Name="ShopModel_LocationError" />

                <!--  Search Location  -->
                <Border Grid.Row="9" Style="{StaticResource PrimaryBorder}">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="searchicon.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            Grid.Column="1"
                            Placeholder="Search location"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SearchText}" />
                    </Grid>
                </Border>

                <!--  Location Results  -->
                <CollectionView
                    Grid.Row="10"
                    ItemsSource="{Binding Places}"
                    x:Name="placesList">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="1"
                            VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Place">
                            <Frame
                                BackgroundColor="Transparent"
                                BorderColor="Transparent"
                                CornerRadius="0"
                                Padding="0">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference AddShopPage}, Path=BindingContext.SelectLocationCommand}" CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <StackLayout>
                                    <Label
                                        FontSize="18"
                                        Text="{Binding Description}"
                                        TextColor="Black" />
                                    <BoxView
                                        Color="Gray"
                                        HeightRequest="1"
                                        HorizontalOptions="FillAndExpand" />
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </ScrollView>

        <!--  Save Button  -->
        <Button
            Command="{Binding AddShopCommand}"
            CommandParameter="{Binding Source={x:Reference AddShopPage}}"
            Grid.Row="1"
            Margin="0"
            Style="{StaticResource PrimaryButton}"
            Text="Save"
            x:Name="btnSave" />
    </Grid>
</ContentPage>