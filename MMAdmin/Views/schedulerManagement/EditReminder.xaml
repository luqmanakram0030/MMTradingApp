<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    Title="EditReminder"
    x:Class="MMAdmin.Views.schedulerManagement.EditReminder"
    x:Name="editReminder"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:MMAdmin.Views.Components"
    xmlns:ext="clr-namespace:MMAdmin.Extension"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <StackLayout>

        <ScrollView VerticalScrollBarVisibility="Never">
            <StackLayout Margin="20,10" Spacing="20">

                <!--#region [ Main Grid ]-->

                <StackLayout Orientation="Horizontal">
                    <!--  Back button  -->
                    <Frame
                        BorderColor="Gray"
                        HorizontalOptions="Start"
                        Padding="0"
                        VerticalOptions="Start">
                        <ImageButton
                            Command="{Binding GoBackCommand}"
                            CommandParameter="{Binding Source={x:Reference editReminder}}"
                            HeightRequest="30"
                            HorizontalOptions="Start"
                            Padding="0"
                            VerticalOptions="Start"
                            x:Name="btngoback">
                            <ImageButton.Source>
                                <FontImageSource
                                    Color="{StaticResource PrimaryBlack}"
                                    FontFamily="FontIcons"
                                    Glyph="&#xf0141;"
                                    Size="40" />
                            </ImageButton.Source>
                        </ImageButton>
                    </Frame>
                    <!--#region [ Text Edit Reminder ]-->
                    <Label
                        FontFamily="Bold"
                        FontSize="20"
                        HorizontalOptions="Start"
                        HorizontalTextAlignment="Center"
                        Margin="20,0"
                        Text="{Binding LblTitle}"
                        TextColor="{StaticResource PrimaryBlack}"
                        VerticalOptions="CenterAndExpand"
                        VerticalTextAlignment="Center" />

                    <!--#endregion-->

                    <!--#region [ Menu Button ]-->

                    <ImageButton
                        Command="{Binding MenuCommand}"
                        HeightRequest="20"
                        HorizontalOptions="EndAndExpand"
                        IsVisible="{Binding MenuIsVisible}"
                        Source="icon_menu.png"
                        VerticalOptions="CenterAndExpand"
                        WidthRequest="20"
                        x:Name="imgBtnMenu" />

                    <!--#endregion-->

                </StackLayout>


                <!--#region [ Row 1 [ Title ]-->
                <StackLayout Grid.Row="1">
                    <Border Style="{StaticResource PrimaryBorder}" x:Name="brdTitle">
                        <Grid
                            ColumnDefinitions="25,*"
                            ColumnSpacing="5"
                            Padding="10,0">
                            <Image Source="icon_schedule.png" Style="{StaticResource PrimaryImageEntry}" />
                            <Entry
                                Grid.Column="1"
                                Placeholder="Title"
                                Style="{StaticResource PrimaryEntry}"
                                Text="{Binding Schedule.Title, Mode=TwoWay}"
                                x:Name="txtTitle" />
                        </Grid>
                    </Border>

                    <Label
                        IsVisible="False"
                        TextColor="Red"
                        x:Name="Schedule_TitleError" />
                </StackLayout>

                <!--#endregion-->


                <!--#region [ Row 4 [ Date ]-->
                <Border
                    Grid.Row="4"
                    Style="{StaticResource PrimaryBorder}"
                    x:Name="brdDate">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="icon_schedule.png" Style="{StaticResource PrimaryImageEntry}" />
                        <ext:ExtDatePicker
                            Date="{Binding Schedule.DateStart, Mode=TwoWay}"
                            Grid.Column="1"
                            NullText="Date"
                            TextColor="Black"
                            x:Name="txtDate" />
                    </Grid>
                </Border>
                <!--#endregion-->

                <!--#region [ Row 5 Hour ]-->
                <Border
                    Grid.Row="5"
                    Style="{StaticResource PrimaryBorder}"
                    x:Name="brdStartTime">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image Source="icon_clock.png" Style="{StaticResource PrimaryImageEntry}" />
                        <ext:ExtTimePicker
                            FontFamily="Medium"
                            Grid.Column="1"
                            NullText="Start Time"
                            NullableTime="{Binding StartTime, Mode=TwoWay}"
                            Time="{Binding StartTime, Mode=TwoWay}"
                            x:Name="txtStartTime" />
                    </Grid>
                </Border>



                <!--#endregion-->

                <!--#region [ Row 7 Notes ]-->
                <Border
                    Grid.Row="7"
                    MinimumHeightRequest="100"
                    Style="{StaticResource PrimaryBorder}"
                    x:Name="brdNotes">
                    <Grid
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5"
                        Padding="10,0">
                        <Image
                            Margin="0,10,0,0"
                            Source="icon_note.png"
                            Style="{StaticResource PrimaryImageEntry}"
                            VerticalOptions="StartAndExpand" />
                        <Editor
                            FontFamily="Medium"
                            Grid.Column="1"
                            HorizontalOptions="FillAndExpand"
                            Placeholder="Note"
                            PlaceholderColor="{StaticResource PrimaryBlack35}"
                            Text="{Binding Schedule.Description}"
                            VerticalOptions="FillAndExpand"
                            VerticalTextAlignment="Start"
                            x:Name="txtNotes" />
                    </Grid>
                </Border>
                <!--#endregion-->


                <!--#endregion-->

                <!--#region [ Save Button ]-->
                <Button
                    Command="{Binding SaveEventCommand}"
                    CommandParameter="{Binding Source={x:Reference editReminder}}"
                    Grid.Row="1"
                    Style="{StaticResource PrimaryButton}"
                    Text="Save"
                    x:Name="btnSave" />
                <!--#endregion-->

            </StackLayout>
        </ScrollView>
    </StackLayout>
</ContentPage>
