<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MMAdmin.Views.EmployeeManagement.AddEmployee"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:MMAdmin.Behaviors"
    xmlns:converters="clr-namespace:MMAdmin.Converters"
    xmlns:vm="clr-namespace:MMAdmin.ViewModels.EmployeeManagement"
    x:Name="addemployeepage"
    Title="AddEmployee"
    x:DataType="vm:AddEmployeeViewModel"
    Shell.NavBarIsVisible="False">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <converters:PasswordVisibilityIconConverter x:Key="PasswordVisibilityIconConverter" />

        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid
        Margin="20,10"
        RowDefinitions="*,Auto"
        RowSpacing="15">
        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="0">
                <StackLayout Orientation="Horizontal">
                    <Frame
                        Padding="0"
                        BorderColor="Gray"
                        HorizontalOptions="Start"
                        VerticalOptions="Start">
                        <ImageButton
                            x:Name="btngoback"
                            Padding="{OnPlatform Android=0,
                                                 iOS=0}"
                            Command="{Binding GoBackCommand}"
                            CommandParameter="{Binding Source={x:Reference addemployeepage}}"
                            HeightRequest="30"
                            HorizontalOptions="Start"
                            VerticalOptions="Start">
                            <ImageButton.Source>
                                <FontImageSource
                                    FontFamily="FontIcons"
                                    Glyph="&#xf0141;"
                                    Size="40"
                                    Color="{StaticResource PrimaryBlack}" />

                            </ImageButton.Source>

                        </ImageButton>
                    </Frame>
                    <Label
                        x:Name="lblTitle"
                        FontFamily="Bold"
                        FontSize="20"
                        HorizontalOptions="CenterAndExpand"
                        Text="{Binding PageTitle}"
                        TextColor="{StaticResource PrimaryBlack}"
                        VerticalOptions="StartAndExpand"
                        VerticalTextAlignment="Center" />
                    <Frame
                        Padding="0"
                        BorderColor="Transparent"
                        HasShadow="False"
                        HorizontalOptions="Start"
                        VerticalOptions="Start">
                        <ImageButton
                            x:Name="imgBtnMenu"
                            Command="{Binding DeleteEmployeeCommand}"
                            HeightRequest="25"
                            HorizontalOptions="EndAndExpand"
                            IsVisible="{Binding IsVisible, Mode=TwoWay}"
                            Source="icon_menu.png"
                            VerticalOptions="Start"
                            WidthRequest="25" />
                    </Frame>
                </StackLayout>



                <Image
                    Margin="0,40,0,0"
                    HeightRequest="160"
                    HorizontalOptions="Center"
                    Source="loginimg.png"
                    VerticalOptions="Center" />
                <Border
                    x:Name="brdFirstname"
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid
                        Padding="10,0"
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5">
                        <Image Source="icon_profile.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            x:Name="txtFirstname"
                            Grid.Column="1"
                            Placeholder="Fullname"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedEmployee.FullName}" />

                    </Grid>
                </Border>

                <Label
                    x:Name="EmployeeModel_FullNameError"
                    Grid.Row="2"
                    IsVisible="False"
                    TextColor="Red" />

                <Border
                    x:Name="brdTelephone"
                    Grid.Row="3"
                    Margin="0,10,0,0"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid
                        Padding="10,0"
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5">
                        <Image Source="icon_call.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            x:Name="txtTelephone"
                            Grid.Column="1"
                            Keyboard="Telephone"
                            Placeholder="Phone#"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedEmployee.PhoneNumber}">
                            <Entry.Behaviors>
                                <behaviors:PhoneNumberMaskBehavior x:Name="PhoneMask" />

                            </Entry.Behaviors>
                        </Entry>

                    </Grid>
                </Border>
                <Label
                    x:Name="EmployeeModel_PhoneNumberError"
                    Grid.Row="4"
                    IsVisible="False"
                    TextColor="Red" />
                <Border
                    x:Name="brdEmail"
                    Grid.Row="5"
                    Margin="0,10,0,0"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid ColumnDefinitions="45,*">
                        <Image
                            Margin="10"
                            Aspect="AspectFit"
                            Source="icon_email.png" />
                        <Entry
                            x:Name="txtEmail"
                            Grid.Column="1"
                            Keyboard="Email"
                            Placeholder="Email"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedEmployee.Email}" />

                    </Grid>
                </Border>
                <Label
                    x:Name="EmployeeModel_EmailError"
                    Grid.Row="6"
                    IsVisible="False"
                    TextColor="Red" />
                <Border
                    x:Name="brdPassword"
                    Grid.Row="7"
                    Margin="0,10,0,0"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid
                        Padding="10,0"
                        ColumnDefinitions="25,*,25"
                        ColumnSpacing="5">
                        <Image Source="icon_lock.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            x:Name="txtPassword"
                            Grid.Column="1"
                            IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBooleanConverter}}"
                            Placeholder="Password"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SelectedEmployee.Password}" />
                        <ImageButton
                            x:Name="btnTogglePasswordVisibility"
                            Grid.Column="2"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            HeightRequest="25"
                            Source="{Binding IsPasswordVisible, Converter={StaticResource PasswordVisibilityIconConverter}}"
                            WidthRequest="25" />
                    </Grid>
                </Border>
                <Label
                    x:Name="EmployeeModel_PasswordError"
                    Grid.Row="8"
                    IsVisible="False"
                    TextColor="Red" />
                <Border
                    x:Name="brdConfirmPassword"
                    Grid.Row="9"
                    Margin="0,10,0,0"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid
                        Padding="10,0"
                        ColumnDefinitions="25,*"
                        ColumnSpacing="5">
                        <Image Source="icon_lock.png" Style="{StaticResource PrimaryImageEntry}" />
                        <Entry
                            x:Name="txtConfirmPassword"
                            Grid.Column="1"
                            IsPassword="True"
                            Placeholder="Confirm Password"
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding ConfirmPassword}" />

                    </Grid>
                </Border>
            </Grid>
        </ScrollView>

        <Button
            x:Name="btnAddEmployee"
            Grid.Row="1"
            Margin="0"
            Command="{Binding AddEmployeeCommand}"
            CommandParameter="{Binding Source={x:Reference addemployeepage}}"
            Style="{StaticResource PrimaryButton}"
            Text="Save" />

        
    </Grid>
 
</ContentPage>
