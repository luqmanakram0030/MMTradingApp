<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MMAdmin.Views.Components.ActivityButtonsTemplate"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="activityButton">

    <Frame
        Padding="10"
        BackgroundColor="{Binding CustomBg}"
        CornerRadius="6"
        HasShadow="True">
        <Frame.GestureRecognizers>
            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
        </Frame.GestureRecognizers>
        <VerticalStackLayout>
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="{Binding OrderCount}"
                TextColor="White" />
            <Label
                FontSize="15"
                Text="{Binding OrderStatus}"
                TextColor="{StaticResource PrimaryBlack}" />
        </VerticalStackLayout>
    </Frame>
</ContentView>