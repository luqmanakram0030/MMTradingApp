<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="True"
    x:Class="MMAdmin.Views.CategoryView"
    x:DataType="vm:CategoryViewModel"
    x:Name="CategoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:models="clr-namespace:MMAdmin.Domain.Models"
    xmlns:res="clr-namespace:MMAdmin.Resources.Languages"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:MMAdmin.ViewModels.CategoryManagement"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <StackLayout>

        <Grid VerticalOptions="FillAndExpand">

            <Grid
                Margin="0,10"
                RowDefinitions="Auto,Auto,*"
                RowSpacing="10">

                <!--#region [ Row 0 [Text Employees] ]-->

                <StackLayout Margin="20" Orientation="Horizontal">
                    <Frame
                        BorderColor="Gray"
                        HorizontalOptions="Start"
                        Padding="0"
                        VerticalOptions="Start">
                        <ImageButton
                            Command="{Binding GoBackCommand}"
                            CommandParameter="{Binding Source={x:Reference CategoryPage}}"
                            HeightRequest="30"
                            HorizontalOptions="Start"
                            Padding="{OnPlatform Android=0,
                                                 iOS=0}"
                            VerticalOptions="Start"
                            x:Name="btngoback">
                            <ImageButton.Source>
                                <FontImageSource
                                    Color="{StaticResource PrimaryBlack}"
                                    FontFamily="FontIcons"
                                    Glyph="&#xf0141;"
                                    Size="40" />

                            </ImageButton.Source>

                        </ImageButton>
                    </Frame>
                    <Label
                        FontFamily="Bold"
                        FontSize="20"
                        HorizontalOptions="CenterAndExpand"
                        Text="Categories"
                        TextColor="{StaticResource PrimaryBlack}"
                        VerticalOptions="CenterAndExpand"
                        x:Name="lblTitle" />


                </StackLayout>

                <!--#endregion-->

                <!--#region [ Search Bar ]-->

                <Border
                    Grid.Row="1"
                    Margin="20"
                    Style="{StaticResource PrimaryBorder}">
                    <Grid ColumnDefinitions="*,25" Padding="10,0">
                        <Entry
                            Placeholder="Search "
                            Style="{StaticResource PrimaryEntry}"
                            Text="{Binding SearchText}" />
                        <Image
                            Grid.Column="1"
                            Source="icon_search.png"
                            Style="{StaticResource PrimaryImageEntry}" />
                    </Grid>
                </Border>

                <!--#endregion-->

                <!--#region [ Employee List ]-->
                <CollectionView
                    BackgroundColor="{StaticResource PrimaryWhite}"
                    Grid.Row="2"
                    ItemsSource="{Binding Categories}"
                    Margin="20,0"
                    SelectionMode="None"
                    VerticalScrollBarVisibility="Never"
                    x:Name="lstEmployees">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Category">
                            <StackLayout>
                                <StackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Path=BindingContext.NavigateToAddCategoryCommand, Source={x:Reference lstEmployees}}" CommandParameter="{Binding .}" />
                                </StackLayout.GestureRecognizers>
                                <Label
                                    FontFamily="Bold"
                                    FontSize="15"
                                    Text="{Binding Name}"
                                    TextColor="{StaticResource PrimaryBlack}" />
                                <Label
                                    FontFamily="Bold"
                                    FontSize="12"
                                    Text="{Binding Description}"
                                    TextColor="{StaticResource PrimaryDarkGray80}" />
                                <BoxView
                                    Color="LightGray"
                                    HeightRequest="0.5"
                                    Margin="0,3,0,0" />
                            </StackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--#endregion-->

            </Grid>

            <!--#region [ Button Add ]-->
            <ImageButton
                Command="{Binding NavigateToAddCategoryCommand}"
                Margin="0,0,20,10"
                Source="icon_add.png"
                Style="{StaticResource PrimaryButtonAdd}"
                VerticalOptions="EndAndExpand"
                x:Name="imgBtnAdd" />

            <!--#endregion-->
        </Grid>
    </StackLayout>
</ContentPage>