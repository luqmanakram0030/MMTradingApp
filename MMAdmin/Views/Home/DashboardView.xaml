<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="{StaticResource PrimaryLightGray}"
    Shell.NavBarIsVisible="False"
    x:Class="MMAdmin.Views.Home.DashboardView"
    x:DataType="viewmodel:DashboardViewModel"
    x:Name="dashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:components="clr-namespace:MMAdmin.Views.Components"
    xmlns:controls="clr-namespace:MMAdmin.Drawables"
    xmlns:viewmodel="clr-namespace:MMAdmin.ViewModels.Home"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Grid RowDefinitions="Auto,*">
        <!-- <components:HeaderTemplete Grid.Row="0" /> -->
        <Label
            FontFamily="Bold"
            FontSize="20"
            Grid.Row="0"
            HorizontalOptions="CenterAndExpand"
            Margin="20,20"
            Text="Dashboard"
            TextColor="{StaticResource PrimaryBlack}"
            VerticalOptions="CenterAndExpand" />
        <ScrollView Grid.Row="1">

            <StackLayout Margin="10" Spacing="15">

                <Frame
                    BackgroundColor="White"
                    BorderColor="White"
                    CornerRadius="8"
                    Padding="20,30">
                    <StackLayout>
                        <!--#region [ Welcome Section]-->
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                            <Label
                                FontFamily="Bold"
                                FontSize="16"
                                Text="Welcome To MMTrading"
                                TextColor="{StaticResource PrimaryBlack}"
                                x:Name="lblUser" />
                            <HorizontalStackLayout Grid.Row="1" Spacing="5">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="15"
                                    Source="icon_calendar.png"
                                    WidthRequest="15" />
                                <Label
                                    FontFamily="Medium"
                                    FontSize="11"
                                    Text="Sales May, 2024"
                                    TextColor="{StaticResource PrimaryBlack35}" />
                            </HorizontalStackLayout>

                            <Label
                                FontFamily="Bold"
                                FontSize="11"
                                Grid.Column="1"
                                HorizontalTextAlignment="End"
                                Text="This Month"
                                TextColor="{StaticResource PrimaryDarkGray}" />
                        </Grid>
                        <!--#endregion-->
                        <!--#region [ Statistics Section ]-->

                        <Grid ColumnDefinitions="*,*" Grid.Row="1">

                            <VerticalStackLayout
                                HorizontalOptions="StartAndExpand"
                                Spacing="5"
                                VerticalOptions="EndAndExpand">
                                <Label
                                    FontFamily="Bold"
                                    FontSize="20"
                                    TextColor="{StaticResource PrimaryBlack}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="$" />
                                            <Span Text="2000" />

                                        </FormattedString>

                                    </Label.FormattedText>

                                </Label>
                                <Label
                                    FontFamily="Medium"
                                    FontSize="15"
                                    HorizontalTextAlignment="Center"
                                    TextColor="{StaticResource PrimaryBlack}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="80" />
                                            <Span Text="% " />
                                            <Span Text="of the goal" />
                                        </FormattedString>

                                    </Label.FormattedText>

                                </Label>
                            </VerticalStackLayout>

                            <controls:CircularProgressBar
                                Fontsize="18"
                                Grid.Column="1"
                                HorizontalOptions="EndAndExpand"
                                Padding="0"
                                Progress="80"
                                ProgressColor="{StaticResource Primary}"
                                ProgressLeftColor="{StaticResource PrimaryLightGray}"
                                Size="70"
                                StrokeLineCap="Round"
                                TextColor="{StaticResource PrimaryBlack}"
                                Thickness="5" />

                        </Grid>

                        <!--#endregion-->
                    </StackLayout>
                </Frame>
                <!--#region [ Activity Section]-->
                <Frame
                    BackgroundColor="White"
                    BorderColor="White"
                    CornerRadius="8"
                    Padding="10">
                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="10">
                        <Label
                            FontFamily="Bold"
                            FontSize="16"
                            Margin="0,10,0,0"
                            Text="Latest Actitvity"
                            TextColor="{StaticResource PrimaryBlack}" />
                        <Label
                            FontFamily="Bold"
                            FontSize="11"
                            Grid.Column="1"
                            HorizontalTextAlignment="End"
                            Text="This Month"
                            TextColor="{StaticResource PrimaryDarkGray}"
                            VerticalTextAlignment="Center" />

                        <components:ActivityButtonsTemplate
                            Activities="5"
                            Command="{Binding NavigateOrderPageCommand}"
                            CommandParameter="{Binding Source={x:Reference dashboardPage}}"
                            Grid.Column="0"
                            Grid.Row="1"
                            Text="Pending Orders"
                            x:Name="btnOrder" />

                        <components:ActivityButtonsTemplate
                            Activities="10"
                            Command="{Binding .}"
                            Grid.Column="1"
                            Grid.Row="1"
                            Text="Appointments" />

                        <components:ActivityButtonsTemplate
                            Activities="5"
                            Command="{Binding .}"
                            Grid.Column="0"
                            Grid.Row="2"
                            Text="Meetings" />

                        <components:ActivityButtonsTemplate
                            Activities="3"
                            Command="{Binding .}"
                            Grid.Column="1"
                            Grid.Row="2"
                            Text="Reminders" />
                    </Grid>
                </Frame>

                <!--#endregion-->
                <!--#region [ Statistics Section]-->
                <Frame
                    BackgroundColor="White"
                    BorderColor="White"
                    CornerRadius="8"
                    Padding="20,30">
                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="10">
                        <Label
                            FontFamily="Bold"
                            FontSize="16"
                            Margin="0,10,0,0"
                            Text="Statistics"
                            TextColor="{StaticResource PrimaryBlack}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            Grid.Column="1"
                            HorizontalTextAlignment="End"
                            Text="This Month"
                            TextColor="{StaticResource PrimaryDarkGray}"
                            VerticalTextAlignment="Center" />

                        <components:StatisticsViewTemplate
                            Grid.Column="0"
                            Grid.Row="1"
                            Icon="graph_down.png"
                            Text="Conversion rate"
                            TextColor="Red"
                            TitleText="10%" />

                        <components:StatisticsViewTemplate
                            Grid.Column="1"
                            Grid.Row="1"
                            Icon="graph_up.png"
                            Text="Reply time"
                            TextColor="Green"
                            TitleText="1:00 Hours" />
                    </Grid>
                </Frame>

                <!--#endregion-->

            </StackLayout>

        </ScrollView>
    </Grid>
</ContentPage>