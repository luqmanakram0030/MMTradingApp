<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MMAdmin.PracticeProjects.Views.DetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="DetailPagesss">
    <ScrollView>

        <VerticalStackLayout>
            <CarouselView x:Name="ImageCarousel"
              HeightRequest="250"
              ItemsSource="{Binding Images}">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding}" Aspect="AspectFill" />
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <Button Text="Add More Images"
        Clicked="Button_Clicked" />

            <!-- Product Details -->
            <Label Text="{Binding Product.Name}" />
            <Label Text="{Binding Product.Price}" />
            <Label Text="{Binding Product.Description}" />
            <Label Text="{Binding Product.Category}" />
            <Label Text="{Binding Product.StockQty}" />

            <Button Text="Edit"
                Command="{Binding ViewModel.EditProductCommand}"
                CommandParameter="{Binding Product}" />

            <Button Text="Delete"
                Command="{Binding ViewModel.DeleteProductCommand}"
                CommandParameter="{Binding Product}" />
        </VerticalStackLayout>

    </ScrollView>
</ContentPage>