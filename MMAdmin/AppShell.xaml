<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    Shell.FlyoutBehavior="Disabled"
    Title="Oportia"
    x:Class="MMAdmin.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:Employee="clr-namespace:MMAdmin.Views.EmployeeManagement"
    xmlns:Home="clr-namespace:MMAdmin.Views.Home"
    xmlns:Shop="clr-namespace:MMAdmin.Views"
    xmlns:login="clr-namespace:MMAdmin.Views.AdminUserMangement"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">



    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="Element" x:Key="BaseStyle">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource PrimarySmokyWhite}" />
                <Setter Property="Shell.NavBarHasShadow" Value="True" />
                <Setter Property="Shell.ForegroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.TitleColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.DisabledColor" Value="#B4FFFFFF" />
                <Setter Property="Shell.UnselectedColor" Value="#95FFFFFF" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource PrimarySmokyWhite}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource PrimaryBlack}" />
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
            </Style>
            <Style BasedOn="{StaticResource BaseStyle}" TargetType="TabBar" />
            <Style BasedOn="{StaticResource BaseStyle}" TargetType="FlyoutItem" />
        </ResourceDictionary>
    </Shell.Resources>

    <FlyoutItem FlyoutDisplayOptions="AsSingleItem" x:Name="MyTabbar">
        <ShellContent
            ContentTemplate="{DataTemplate Home:DashboardView}"
            Route="DashboardView"
            Title="Dashboard"
            x:Name="DashboardViewTab" />

        <ShellContent
            ContentTemplate="{DataTemplate Shop:ShopView}"
            Route="ShopView"
            Title="Shops"
            x:Name="ShopViewTab" />

        <ShellContent
            ContentTemplate="{DataTemplate Shop:ProductView}"
            Route="ProductView"
            Title="Products"
            x:Name="ProductViewTag" />

        <ShellContent
            ContentTemplate="{DataTemplate Shop:EmployeeView}"
            Route="EmployeeView"
            Title="Employee"
            x:Name="EmployeeViewTab" />

        <ShellContent
            ContentTemplate="{DataTemplate Shop:SchedulerView}"
            Route="ScheduleViewTab"
            Title="Schedule" />

        <!--<ShellContent x:Name="NotificationsView" Route="NotificationsView" Title="Notifications"  ContentTemplate="{DataTemplate Home:NotificationView}"/>-->


    </FlyoutItem>

    <ShellContent
        ContentTemplate="{DataTemplate login:AdminLoginView}"
        Route="LoginPage"
        Shell.FlyoutBehavior="Disabled"
        Shell.FlyoutItemIsVisible="False"
        x:Name="Login" />





    <Shell.ItemTemplate>
        <DataTemplate>
            <ContentView BackgroundColor="White">
                <!--  Bindable Properties: Title, Icon  -->
                <Grid
                    ColumnDefinitions="2,*"
                    Padding="0,25,0,2"
                    RowDefinitions="auto,1">
                    <Image
                        HeightRequest="28"
                        Source="{Binding Icon}"
                        VerticalOptions="Center" />
                    <Label
                        FontFamily="SemiBold"
                        FontSize="16"
                        Grid.Column="1"
                        HorizontalTextAlignment="Start"
                        Margin="10,5,0,0"
                        Text="{Binding Title}"
                        TextColor="Black"
                        VerticalTextAlignment="Center" />
                </Grid>
            </ContentView>
        </DataTemplate>
    </Shell.ItemTemplate>


    <!--
        // MenuItemTemplate is for MenuItems as displayed in a Flyout
        // https://docs.microsoft.com/xamarin/xamarin-forms/app-fundamentals/shell/flyout#define-menuitem-appearance
    -->
    <Shell.MenuItemTemplate>
        <DataTemplate>
            <ContentView BackgroundColor="White">
                <!--  Bindable Properties: Text, Icon  -->
                <Grid
                    ColumnDefinitions="30,*"
                    Padding="20,10,0,0"
                    RowDefinitions="auto,10"
                    RowSpacing="0">
                    <Image
                        HeightRequest="28"
                        Source="{Binding Icon}"
                        VerticalOptions="Center" />
                    <Label
                        FontFamily="SemiBold"
                        FontSize="16"
                        Grid.Column="1"
                        HorizontalTextAlignment="Start"
                        Margin="10,5,0,0"
                        Text="{Binding Title}"
                        TextColor="Black"
                        VerticalTextAlignment="Center" />
                    <BoxView
                        BackgroundColor="#757575"
                        Grid.ColumnSpan="2"
                        Grid.Row="1"
                        HeightRequest="0.5"
                        HorizontalOptions="FillAndExpand"
                        Margin="-70,0,0,0"
                        Opacity="0.8"
                        VerticalOptions="EndAndExpand" />
                </Grid>
            </ContentView>
        </DataTemplate>
    </Shell.MenuItemTemplate>

</Shell>